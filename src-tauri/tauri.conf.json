{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Athena Nexus",
  "version": "0.1.0",
  "identifier": "org.athenaos.nexus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Athena Nexus",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["docker", "podman", "webkit2gtk-4.1"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
